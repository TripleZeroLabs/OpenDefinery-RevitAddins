<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Single entry point for the OpenDefinery theme. Merge this from
         a Window (add-in) or App (standalone), e.g.:

           <ResourceDictionary.MergedDictionaries>
             <ResourceDictionary Source="pack://application:,,,/OpenDefinery.Theme;component/Themes/Theme.xaml" />
           </ResourceDictionary.MergedDictionaries>
         ============================================================ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/OpenDefinery.Theme;component/Themes/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/OpenDefinery.Theme;component/Themes/Controls.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
