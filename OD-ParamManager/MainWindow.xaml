<Window x:Class="OpenDefinery_DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenDefinery_DesktopApp"
        mc:Ignorable="d"
        Title="OpenDefinery"
        FontFamily="Segoe UI"
        FontSize="13"
        Background="{DynamicResource OD.Brush.Background}"
        MinWidth="850"
        MinHeight="600"
        d:DesignWidth="1600"
        d:DesignHeight="1000">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/OpenDefinery.Theme;component/Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Toolbar button: transparent on the dark toolbar, light text -->
            <Style x:Key="OD.ToolbarButton" TargetType="{x:Type Button}">
                <Setter Property="Foreground" Value="{DynamicResource OD.Brush.ToolbarForeground}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A4658" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#7E8895" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="Foreground" Value="{DynamicResource OD.Brush.TextPrimary}" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Background" Value="{DynamicResource OD.Brush.Primary}" />
                        <Setter Property="Foreground" Value="White" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <ContextMenu x:Key="ParamContextMenu">
                <MenuItem x:Name="ParamMenuAdd" Header="Add To Collection" Click="ParamMenuAdd_Click" />
                <MenuItem x:Name="ParamMenuFork" Header="Fork" Click="ParamMenuFork_Click" />
                <MenuItem x:Name="ParamMenuEdit" Header="Edit" Click="ParamMenuEdit_Click" />
                <MenuItem x:Name="ParamMenuRemove" Header="Remove From Collection" Click="ParamMenuRemove_Click" />
            </ContextMenu>
        </ResourceDictionary>
    </Window.Resources>
    <Grid x:Name="MainGrid" Margin="0">
        <Grid x:Name="MainUiGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="57"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="62.4"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width = "*" />
            </Grid.ColumnDefinitions>

            <!-- Success/Status Banner (Reusable) -->
            <Grid x:Name="StatusBanner" Grid.Row="1" Background="{DynamicResource OD.Brush.Success}" Height="50" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBannerIcon" Grid.Column="0" Text="&#x2714;" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="20,0,10,0"/>
                <TextBlock x:Name="StatusBannerText" Grid.Column="1" Text="Success!" Foreground="White" FontSize="14" VerticalAlignment="Center" FontWeight="Medium"/>
                <Button x:Name="StatusBannerCloseButton" Grid.Column="2" Style="{StaticResource OD.ToolbarButton}" Click="StatusBannerCloseButton_Click" Width="30" Height="30" Margin="10,0,10,0" Content="&#x2715;"/>
            </Grid>

            <Grid x:Name="ToolbarGrid" Height="57" VerticalAlignment="Top" Margin="0,0,-0.4,0" Background="{DynamicResource OD.Brush.Toolbar}" Grid.Row="0" Grid.RowSpan="2">
                <StackPanel Margin="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource OD.ToolbarButton}" x:Name="DashboardButton" Margin="20,0,0,0" ToolTip="See all of the things" Click="DashboardButton_Click" Content="Home"/>
                    <Button Style="{StaticResource OD.ToolbarButton}" x:Name="NewParameterButton" Margin="10,0,0,0" Click="NewParameterButton_Click" ToolTip="Create a new Shared Parameter" Content="New Parameter"/>
                    <Button Style="{StaticResource OD.ToolbarButton}" x:Name="NewCollectionButton" Margin="10,0,0,0" Click="NewCollectionButton_Click" ToolTip="Collections are used to group Shared Parameters." Content="New Collection"/>
                    <Button Style="{StaticResource OD.ToolbarButton}" x:Name="BatchUploadOverlayButton" Click="BatchUploadOverlayButton_Click" Margin="10,0,0,0" ToolTip="Import a Shared Parameter text file" Content="Batch Upload"/>
                    <Button Style="{StaticResource OD.ToolbarButton}" x:Name="AddToFamilyButton" Click="AddToFamilyButton_Click" Margin="10,0,0,0" ToolTip="Add the selected parameters to the currently open Revit family or project" Content="Add to Family"/>
                </StackPanel>
                <TextBox x:Name="SearchTxtBox" HorizontalAlignment="Right" Margin="0,0,69,0" VerticalAlignment="Center" TabIndex="0" Width="231" Height="28" KeyDown="PressEnterToSearch" FontSize="12" ToolTip="Search by keyword, data type, or GUID..."/>
                <Button x:Name="SearchButton" Content="Find" Style="{StaticResource OD.ToolbarButton}" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Center" Height="28" IsCancel="True" Width="56" Click="SearchButton_Click" ToolTip="Search by keyword, data type, or GUID..."/>
            </Grid>
            <DockPanel x:Name="MainPanel" LastChildFill="True" Margin="0" Grid.Row="2">
                <ScrollViewer Background="{DynamicResource OD.Brush.Surface}" Height="Auto" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row ="0" x:Name="SidebarStack" Width="219" Margin="0,0,0,0.2" CanVerticallyScroll="True">
                            <Label Content="MY COLLECTIONS" Padding="17,4,4,4" Margin="0,10,0,0" FontSize="11" FontWeight="Bold"/>
                            <ListBox x:Name="CollectionsList" Margin="10,0,9.8,0" BorderThickness="0" Background="Transparent" SelectionChanged="CollectionsList_SelectionChanged" />
                            <Label Content="PUBLISHED COLLECTIONS" Padding="17,4,4,4" Margin="0,20,0,0" FontSize="11" FontWeight="Bold"/>
                            <ListBox x:Name="CollectionsList_Published" Margin="10,0,9.8,0" BorderThickness="0" Background="Transparent" SelectionChanged="CollectionsList_Published_SelectionChanged" />
                            <Label Content="OTHER" Padding="17,4,4,4" Margin="0,20,0,0" FontSize="11" FontWeight="Bold" Height="21"/>
                            <ListBox x:Name="OrphanedList" Margin="10,0,9.8,0" BorderThickness="0" Background="Transparent">
                                <ListBoxItem x:Name="OrphanedListItem" Selected="OrphanedListBox_Selected" Content="Orphaned Params"/>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                <Grid x:Name="DashboardGrid" HorizontalAlignment="Center" VerticalAlignment="Center" DockPanel.Dock="Top" Visibility="Collapsed">
                    <TextBlock TextWrapping="Wrap" Text="Welcome to OpenDefinery" Margin="0,100,0,0" VerticalAlignment="Top" FontSize="36" Foreground="#DD767676" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DashboardVersionText" Margin="0,155,0,0" TextWrapping="Wrap" Text="(beta)" VerticalAlignment="Top" FontSize="15" HorizontalAlignment="Center" Foreground="#DD767676"/>
                </Grid>
                <Grid x:Name="MainBrowserGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <StackPanel x:Name="CollectionToolStack" Orientation="Horizontal" Height="Auto" d:IsHidden="True">
                            <Button Style="{StaticResource OD.Button.Secondary}" x:Name="ExportCollectionButton" HorizontalAlignment="Center" Click="ExportCollectionTxtButton_Click" Margin="10,8,0,8" ToolTip="Export the current set of Shared Parameters to a text file" Content="Export"/>
                            <Button Style="{StaticResource OD.Button.Flat}" x:Name="DeleteCollectionButton" HorizontalAlignment="Left" Margin="10,8,0,8" ToolTip="Delete the current Collection" Click="DeleteCollectionButton_Click" Content="Delete Collection"/>
                        </StackPanel>
                        <StackPanel Background="{DynamicResource OD.Brush.Surface}" x:Name="SearchToolStack" Orientation="Horizontal" Height="Auto">
                            <Label Content="DATATYPE" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <ComboBox x:Name="SearchFilterDataTypeCombo" VerticalAlignment="Center" Width="300" Height="32" Margin="10,0,0,0" SelectionChanged="SearchFilterDataTypeCombo_SelectionChanged" ToolTip="Filter search results by data type."/>
                            <Button Style="{StaticResource OD.Button.Secondary}" x:Name="ClearSearchButton" Content="Reset Search" Height="Auto" Width="Auto" ToolTip="Clear the search query and start over" VerticalAlignment="Center" Margin="15,8,0,8" Click="ClearSearchButton_Click"/>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Empty Collection State -->
                        <Grid x:Name="EmptyCollectionGrid" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="This collection is empty." FontSize="24" Foreground="#999999" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                <TextBlock Text="Get started by adding parameters" FontSize="14" Foreground="#BBBBBB" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                                    <Button x:Name="EmptyStateNewParamButton" Click="EmptyStateNewParamButton_Click" Margin="0,0,10,0" Height="40" Padding="20,0" Content="New Parameter"/>
                                    <Button Style="{StaticResource OD.Button.Secondary}" x:Name="EmptyStateBatchUploadButton" Click="EmptyStateBatchUploadButton_Click" Margin="10,0,0,0" Height="40" Padding="20,0" Content="Batch Upload"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <DataGrid
                            x:Name="DataGridParameters"
                            Margin="10,0"
                            IsReadOnly="True"
                            SelectionUnit="FullRow"
                            SelectionChanged="DataGridParameters_SelectionChanged"
                            AutoGenerateColumns="False"
                            Grid.Column="0"
                            MouseRightButtonUp="DataGridParameters_MouseRightButtonUp">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <EventSetter Event="MouseRightButtonUp" Handler="DataGridParameters_MouseRightButtonUp"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" x:Name="ContextualMenuColumn">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                x:Name="ParamContextMenu"
                                                Style="{StaticResource OD.Button.Flat}"
                                                Foreground="#999999"
                                                Margin="0"
                                                Content="&#x22EE;"
                                                Click="ParamContextMenu_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Param" x:Name="ParamColumn" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" Width="Auto">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Guid}" Foreground="{DynamicResource OD.Brush.TextSecondary}" FontFamily="Consolas" FontSize="11" />
                                                <TextBlock TextWrapping="Wrap" Text="{Binding Description}" Foreground="{DynamicResource OD.Brush.TextSecondary}" FontSize="11" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="300" Visibility="Hidden"/>
                                <DataGridTemplateColumn Header="Collections" x:Name="CollectionsColumn">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ItemsControl ItemsSource="{Binding Collections}" DisplayMemberPath="Name"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid x:Name="PropertiesSideBar"  Width="300" Grid.Column="1" Background="{DynamicResource OD.Brush.Surface}">
                            <StackPanel Margin="20,20,20,20">
                                <Label Content="GUID" Margin="0" Padding="0,4,4,4"/>
                                <TextBox x:Name="PropTextGuid" Height="28" VerticalAlignment="Top" Margin="0" IsEnabled="False"/>
                                <Label Content="DataType" Margin="0,20,0,0" Padding="0,4,4,4"/>
                                <ComboBox x:Name="PropComboDataType" VerticalAlignment="Stretch" IsEnabled="False"/>
                                <Label x:Name="PropComboLabelDataCategory" Content="DataCategory" Margin="0,20,0,0" Padding="0,4,4,4"/>
                                <ComboBox x:Name="PropComboDataCategory" VerticalAlignment="Stretch" IsEnabled="False"/>
                                <CheckBox x:Name="PropCheckVisible" Content="Visible" Margin="0,20,0,0" IsEnabled="False"/>
                                <CheckBox x:Name="PropCheckUserMod" Content="User Modifiable" Margin="0,10,0,0" IsEnabled="False"/>
                                <Button Style="{StaticResource OD.Button.Secondary}" FontSize="13" x:Name="PropCopyPasteRowButton" Click="PropCopyPasteRowButton_Click" ToolTip="Copy this Shared Parameter as a tab delimited line of text" Margin="0,30,0,0" Content="Copy PARAM"/>
                                <TextBlock x:Name="PropTxtRowCopied" TextWrapping="Wrap" Text="PARAM data copied to clipboard" Margin="10,10,10,0" Padding="10,5" Background="#FFE3FFD7" Foreground="#DD095A00"/>
                                <TextBox x:Name="PropTxtRow" Height="23" Margin="0" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Left" Visibility="Hidden"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </DockPanel>
            <Grid x:Name="FooterGrid" Grid.Row="3" Background="{DynamicResource OD.Brush.Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" TextWrapping="Wrap" Text="Support" VerticalAlignment="Center" Margin="20,0,0,0" HorizontalAlignment="Left" FontSize="13" TextDecorations="Underline" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Cursor="Help"/>
                <Grid Width="Auto" Grid.Column="1">
                    <StackPanel FlowDirection="RightToLeft" x:Name="PagerPanel" Height="45" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,20,0">
                        <Button Style="{StaticResource OD.Button.Flat}" x:Name="PagerNextButton" Click="PagerNextButton_Click" Margin="10,0,0,0" Height="30" Padding="10, 0" Content="Next &#x203A;"/>
                        <Button Style="{StaticResource OD.Button.Flat}" x:Name="PagerPreviousButton" Margin="10,0,0,0" Click="PagerPreviousButton_Click" Height="30" Padding="10, 0" Content="&#x2039; Previous"/>
                        <Button Style="{StaticResource OD.Button.Flat}" x:Name="PagerLoadAllButton" Margin="20,0,0,0" Height="30" Padding="10, 0" Click="PagerLoadAllButton_Click" Content="View All"/>
                        <TextBlock Text="Page 1 of 120" x:Name="PagerTextBox" Foreground="#888888" TextAlignment="Right" VerticalAlignment="Center" TextWrapping="Wrap" Width="Auto" Margin="10,0,0,0" />
                        <TextBlock x:Name="StatusTextBlock" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="300,0,0,0"/>
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" x:Name="StatusProgressBar" IsIndeterminate="True" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0" Width="200" Height="20" Visibility="Hidden" />
                </Grid>
            </Grid>
        </Grid>
        <Grid x:Name="OverlayGrid" Background="{DynamicResource OD.Brush.Overlay}" d:IsHidden="True">
            <Grid x:Name="LoginGrid" Margin="0" Background="{DynamicResource OD.Brush.Card}" Height="350" VerticalAlignment="Top" Width="400" HorizontalAlignment="Center" d:IsHidden="True">
                <PasswordBox x:Name="PasswordPasswordBox" Margin="50,150,50,0" Height="37" VerticalAlignment="Top" TabIndex="1" FontSize="16"/>
                <TextBox x:Name="UsernameTextBox" Margin="50,50,50,0" Height="37" VerticalAlignment="Top" TabIndex="0" VerticalContentAlignment="Center" FontSize="16"/>
                <Button x:Name="LoginButton" Content="Login" Margin="50,0,50,75" VerticalAlignment="Bottom" Click="LoginButton_Click" IsDefault="True" TabIndex="2" Height="46" FontSize="18"/>
                <Label Content="USERNAME" Margin="45,25,50,0" VerticalAlignment="Top" FontSize="12" Height="20"/>
                <Label Content="PASSWORD" Margin="45,125,50,0" FontSize="12" Height="20" VerticalAlignment="Top"/>
                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,25" TextWrapping="Wrap" VerticalAlignment="Bottom"><Hyperlink RequestNavigate="HandleLinkClick" NavigateUri="http://app.opendefinery.com/user/password"><InlineUIContainer>
                            <TextBlock Text="Forgot Password" Foreground="{DynamicResource OD.Brush.TextSecondary}" TextDecorations="Underline"/>
                        </InlineUIContainer></Hyperlink><Run Text=" "/><Run Text=" "/><InlineUIContainer>
                        <TextBlock Text="|" Margin="15,0" />
                    </InlineUIContainer><Run Text=" "/><Run Text=" "/><Run Text=" "/><Hyperlink RequestNavigate="HandleLinkClick" NavigateUri="http://app.opendefinery.com/user/register"><InlineUIContainer>
                                <TextBlock Foreground="{DynamicResource OD.Brush.TextSecondary}" Text="Register for an Account" TextDecorations="Underline"/>
                            </InlineUIContainer></Hyperlink></TextBlock>
            </Grid>
            <Grid x:Name="ProgressGrid" Margin="0" VerticalAlignment="Top" Width="400" Background="{DynamicResource OD.Brush.Card}" Height="110" d:IsHidden="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="0,25,0,0" TextWrapping="Wrap" Text="Uploading parameters..." VerticalAlignment="Top" TextAlignment="Center" Height="26" UseLayoutRounding="True"/>
                <TextBlock x:Name="ProgressStatus" TextWrapping="Wrap" VerticalAlignment="Bottom" TextAlignment="Center" Height="24" UseLayoutRounding="True" FontSize="9"/>
                <ProgressBar x:Name="MainProgressBar" Height="20" Margin="0,50,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="370"/>
            </Grid>
            <Grid x:Name="BatchUploadGrid" Height="270" Margin="0" VerticalAlignment="Top" Background="{DynamicResource OD.Brush.Card}" HorizontalAlignment="Center" Width="540" d:IsHidden="True">
                <Button Style="{StaticResource OD.Button.Secondary}" x:Name="BrowseForTxtButton" Content="Browse" VerticalAlignment="Top" Height="24" Padding="16,0" Click="BrowseForTxtButton_Click" FontSize="12" Margin="0,64,20,0" HorizontalAlignment="Right" Width="75"/>
                <Button x:Name="BttnUpload" Margin="0,0,20,31" Click="BttnUpload_Click" Height="41" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="207" Content="Batch Load All Parameters"/>
                <TextBox x:Name="TxtBoxSpPath" Margin="20,64,100,0" Height="24" VerticalAlignment="Top" HorizontalContentAlignment="Left" IsReadOnly="True"/>
                <Label Content="ADD TO A COLLECTION" Margin="20,121,20,0" FontSize="12" Height="26" VerticalAlignment="Top" Padding="0,4,4,4"/>
                <Label Content="CHOOSE A SHARED PARAMETER TXT FILE" Margin="20,38,20,0" FontSize="12" Height="26" VerticalAlignment="Top" Padding="0,4,4,4"/>
                <Button x:Name="BatchUploadCancel" Style="{StaticResource OD.Button.Flat}" Content="Cancel" Margin="20,0,0,31" Height="41" Click="BatchUploadCancel_Click" IsCancel="True" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="116"/>
                <ComboBox x:Name="BatchUploadCollectionCombo" Margin="20,147,20,0" VerticalAlignment="Top"/>
            </Grid>
            <Grid x:Name="AddToCollectionGrid" Margin="0" Background="{DynamicResource OD.Brush.Card}" HorizontalAlignment="Center" Width="501" Height="237" VerticalAlignment="Top" d:IsHidden="True">
                <Button x:Name="AddToCollectionFormButton" Content="Add to Collection" HorizontalAlignment="Center" Margin="0,121,0,0" VerticalAlignment="Top" Width="380" Click="AddToCollectionFormButton_Click"/>
                <ComboBox x:Name="AddToCollectionCombo" Margin="0,64,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380"/>
                <Label Content="CHOOSE A COLLECTION" Margin="0,37,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380"/>
                <Button Style="{StaticResource OD.Button.Flat}" x:Name="CancelAddToCollectionButton" Content="Cancel" HorizontalAlignment="Center" Margin="0,171,0,0" VerticalAlignment="Top" Width="380" IsCancel="True" Click="CancelAddToCollectionButton_Click_1" />
            </Grid>
            <Grid x:Name="NewParameterGrid" Margin="0" Background="{DynamicResource OD.Brush.Card}" HorizontalAlignment="Center" Width="501" VerticalAlignment="Top" d:IsHidden="True">
                <StackPanel Margin="0">
                    <Label Content="CHOOSE A COLLECTION" Margin="0,50,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <ComboBox x:Name="NewParamFormCollectionsCombo" Margin="0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" SelectionChanged="NewParamFormCollectionsCombo_SelectionChanged"/>
                    <Label Content="NAME" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <TextBox x:Name="NewParamNameTextBox" HorizontalAlignment="Center" Height="36" Margin="0" VerticalAlignment="Top" Width="380" VerticalContentAlignment="Center"/>
                    <Label Content="GUID" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <TextBox x:Name="NewParamGuidTextBox" HorizontalAlignment="Center" Height="36" Margin="0" VerticalAlignment="Top" Width="380" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="ForkedParamIdTextBox" HorizontalAlignment="Center" Height="36" Margin="60.4,0" VerticalAlignment="Top" Width="380" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                    <Label Content="DATA TYPE" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <ComboBox x:Name="NewParamDataTypeCombo" HorizontalAlignment="Center" VerticalAlignment="Top" Width="380" SelectionChanged="NewParamDataTypeCombo_SelectionChanged"/>
                    <Label x:Name="NewParamDataCatLabel" Content="DATA CATEGORY" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <ComboBox x:Name="NewParamDataCatCombo" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380"/>
                    <Label Content="DESCRIPTION" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <TextBox x:Name="NewParamDescTextBox" HorizontalAlignment="Center" Height="100" Margin="60,0,60.8,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="380" MaxLength="260" VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Left"/>
                    <Grid Height="25" Margin="60,40,60.8,0" Width="380" HorizontalAlignment="Center">
                        <CheckBox x:Name="NewParamVisibleCheck" Content="VISIBLE" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0" IsChecked="True"/>
                        <CheckBox x:Name="NewParamUserModCheckbox" Content="USER MODIFIABLE" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0" IsChecked="True"/>
                    </Grid>
                    <Button x:Name="AddParamFormButton" Content="Create Parameter" HorizontalAlignment="Center" Margin="0,40,0,0" VerticalAlignment="Bottom" Width="379" Click="NewParamFormButton_Click" />
                    <Button Style="{StaticResource OD.Button.Flat}" x:Name="CancelAddParamButton" Content="Cancel" HorizontalAlignment="Center" Margin="0,0,0,20" VerticalAlignment="Bottom" Width="380" IsCancel="True" Click="CancelNewParamButton_Click" />
                </StackPanel>
            </Grid>
            <Grid x:Name="NewCollectionGrid" Margin="0" Width="600" HorizontalAlignment="Center" VerticalAlignment="Top" Background="{DynamicResource OD.Brush.Card}">
                <StackPanel>
                    <Label Content="NAME OF NEW COLLECTION" HorizontalAlignment="Center" Margin="0,50,0,0" VerticalAlignment="Top" Padding="0,4,4,4" Width="380"/>
                    <TextBox x:Name="NewCollectionFormTextBox" HorizontalAlignment="Center" Margin="0" VerticalAlignment="Top" Width="380"/>
                    <Label Content="DESCRIPTION" HorizontalAlignment="Center" Margin="0,50,0,0" VerticalAlignment="Top" Padding="0,4,4,4" Width="380"/>
                    <TextBox x:Name="NewCollectionFormDesc" HorizontalAlignment="Center" Margin="110,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="380" Height="118" HorizontalContentAlignment="Left"/>
                    <CheckBox x:Name="NewCollectionFormPublic" Content="Make this Collection public" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="110,30,0,0" ToolTip="Public Collections are visible to all OpenDefinery users"/>
                    <Button x:Name="NewCollectionFormSaveButton" Content="Save Collection" HorizontalAlignment="Center" Margin="0,30,0,0" VerticalAlignment="Top" Width="380" Click="NewCollectionFormSaveButton_Click"/>
                    <Button Style="{StaticResource OD.Button.Flat}" x:Name="NewCollectionFormCancelButton" Content="Cancel" HorizontalAlignment="Center" Margin="0,20" VerticalAlignment="Top" Width="380" IsCancel="True" Click="NewCollectionFormCancelButton_Click"/>
                </StackPanel>
            </Grid>
            <Grid x:Name="ModifyParameterGrid" Margin="0" Background="{DynamicResource OD.Brush.Card}" HorizontalAlignment="Center" Width="501" VerticalAlignment="Top" d:IsHidden="True">
                <StackPanel Margin="0">
                    <Label Content="NAME" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <TextBox x:Name="ModParamNameTextBox" HorizontalAlignment="Center" Height="36" Margin="0" VerticalAlignment="Top" Width="380" VerticalContentAlignment="Center"/>
                    <Label Content="DESCRIPTION" Margin="0,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="380" Padding="0,4,4,4"/>
                    <TextBox x:Name="ModParamDescTextBox" HorizontalAlignment="Center" Height="100" Margin="60,0,60.8,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="380" MaxLength="260" VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Left"/>
                    <Button x:Name="ModParamFormButton" Content="Save" HorizontalAlignment="Center" Margin="0,40,0,0" VerticalAlignment="Bottom" Width="379" Click="ModParamFormButton_Click" />
                    <Button Style="{StaticResource OD.Button.Flat}" x:Name="CancelModParamButton" Content="Cancel" HorizontalAlignment="Center" Margin="0,0,0,20" VerticalAlignment="Bottom" Width="380" IsCancel="True" Click="CancelModParamButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
